<div id="<%= dom_id employee %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Name:</strong>
    <%= employee.name %>
  </div>
  <div>
    <strong class="block font-medium mb-1">User:</strong>
    <%= employee.user_id %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Company:</strong>
    <%= employee.company_id %>
  </div>
</div>
