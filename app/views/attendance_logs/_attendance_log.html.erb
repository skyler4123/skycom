<div id="<%= dom_id attendance_log %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Company group:</strong>
    <%= attendance_log.company_group_id %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Company:</strong>
    <%= attendance_log.company_id %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Customer:</strong>
    <%= attendance_log.customer_id %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Logable:</strong>
    <%= attendance_log.logable_id %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Period:</strong>
    <%= attendance_log.period_id %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Location:</strong>
    <%= attendance_log.location %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Id address:</strong>
    <%= attendance_log.id_address %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Device info:</strong>
    <%= attendance_log.device_info %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Notes:</strong>
    <%= attendance_log.notes %>
  </div>
</div>
