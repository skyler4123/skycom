<div id="<%= dom_id system_subscription_plan %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Price:</strong>
    <%= system_subscription_plan.price_id %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Name:</strong>
    <%= system_subscription_plan.name %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Description:</strong>
    <%= system_subscription_plan.description %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Code:</strong>
    <%= system_subscription_plan.code %>
