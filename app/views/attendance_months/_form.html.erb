<%= form_with(model: attendance_month, class: "contents") do |form| %>
  <% if attendance_month.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(attendance_month.errors.count, "error") %> prohibited this attendance_month from being saved:</h2>

      <ul class="list-disc ml-6">
        <% attendance_month.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5">
    <%= form.label :company_group_id %>
    <%= form.text_field :company_group_id, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": attendance_month.errors[:company_group_id].none?, "border-red-400 focus:outline-red-600": attendance_month.errors[:company_group_id].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :company_id %>
    <%= form.text_field :company_id, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": attendance_month.errors[:company_id].none?, "border-red-400 focus:outline-red-600": attendance_month.errors[:company_id].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :customer_id %>
    <%= form.text_field :customer_id, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": attendance_month.errors[:customer_id].none?, "border-red-400 focus:outline-red-600": attendance_month.errors[:customer_id].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :logable_id %>
    <%= form.text_field :logable_id, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": attendance_month.errors[:logable_id].none?, "border-red-400 focus:outline-red-600": attendance_month.errors[:logable_id].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :period_id %>
    <%= form.text_field :period_id, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": attendance_month.errors[:period_id].none?, "border-red-400 focus:outline-red-600": attendance_month.errors[:period_id].any?}] %>
  </div>

  <div class="inline">
    <%= form.submit class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
  </div>
<% end %>
