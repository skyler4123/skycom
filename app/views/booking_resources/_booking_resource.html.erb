<div id="<%= dom_id booking_resource %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Company group:</strong>
    <%= booking_resource.company_id %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Company:</strong>
    <%= booking_resource.branch_id %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Booking resourceable:</strong>
    <%= booking_resource.booking_resourceable_id %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Name:</strong>
    <%= booking_resource.name %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Description:</strong>
    <%= booking_resource.description %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Lifecycle status:</strong>
    <%= booking_resource.lifecycle_status %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Workflow status:</strong>
    <%= booking_resource.workflow_status %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Business type:</strong>
    <%= booking_resource.business_type %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Discarded at:</strong>
    <%= booking_resource.discarded_at %>
  </div>
</div>
