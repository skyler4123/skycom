<%= form_with(model: booking_period, class: "contents") do |form| %>
  <% if booking_period.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(booking_period.errors.count, "error") %> prohibited this booking_period from being saved:</h2>

      <ul class="list-disc ml-6">
        <% booking_period.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5">
    <%= form.label :booking_resource_id %>
    <%= form.text_field :booking_resource_id, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": booking_period.errors[:booking_resource_id].none?, "border-red-400 focus:outline-red-600": booking_period.errors[:booking_resource_id].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :period_id %>
    <%= form.text_field :period_id, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": booking_period.errors[:period_id].none?, "border-red-400 focus:outline-red-600": booking_period.errors[:period_id].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :lifecycle_status %>
    <%= form.number_field :lifecycle_status, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": booking_period.errors[:lifecycle_status].none?, "border-red-400 focus:outline-red-600": booking_period.errors[:lifecycle_status].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :workflow_status %>
    <%= form.number_field :workflow_status, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": booking_period.errors[:workflow_status].none?, "border-red-400 focus:outline-red-600": booking_period.errors[:workflow_status].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :business_type %>
    <%= form.number_field :business_type, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": booking_period.errors[:business_type].none?, "border-red-400 focus:outline-red-600": booking_period.errors[:business_type].any?}] %>
  </div>

  <div class="inline">
    <%= form.submit class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
  </div>
<% end %>
