<div id="<%= dom_id booking_period %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Booking resource:</strong>
    <%= booking_period.booking_resource_id %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Period:</strong>
    <%= booking_period.period_id %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Lifecycle status:</strong>
    <%= booking_period.lifecycle_status %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Workflow status:</strong>
    <%= booking_period.workflow_status %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Business type:</strong>
    <%= booking_period.business_type %>
  </div>
</div>
